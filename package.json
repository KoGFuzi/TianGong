{
  "name": "tiangong",
  "type": "module",
  "version": "1.0.3",
  "scripts": {
    "postinstall": "bun -e \"try{require('fs').chmodSync('./bin/tiangong.tsx',0o755);require('fs').chmodSync('./bin/tiangong-cli.ts',0o755)}catch{}\"",
    "start": "bun run bin/tiangong.tsx",
    "tui": "bun run bin/tiangong.tsx",
    "cli": "bun run bin/tiangong-cli.ts",
    "headless": "bun run apps/headless/index.ts"
  },
  "bin": {
    "tiangong": "./bin/tiangong.tsx",
    "tiangong-cli": "./bin/tiangong-cli.ts"
  },
  "files": [
    "bin/",
    "apps/",
    "config/",
    "kernel/",
    "model/",
    "tool/",
    "runtime/",
    "skill/"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.4",
    "@ai-sdk/openai": "^4.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^7.0.9",
    "ink": "^7.1.0",
    "mitt": "^3.0.1",
    "react": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  }
}
